#!name=Surge IP Labeler
#!desc=Safely labels a private Surge policy feed with exit-IP intelligence.
#!arguments=configuration=REQUIRED_CONFIGURATION

[Script]
surge-ip-labeler = type=cron, cronexp="* * * * *", script-path=https://WORKER/surge-ip-labeler.js, timeout=900, script-update-interval=86400, argument="%configuration%"
