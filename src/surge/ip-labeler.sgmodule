#!name=Surge IP Labeler
#!desc=Safely labels a private Surge policy feed with exit-IP intelligence.
#!arguments=source_url=REQUIRED_SOURCE_URL&upload_url=REQUIRED_UPLOAD_URL&upload_token=REQUIRED_SYNC_TOKEN

[Script]
surge-ip-labeler = type=cron, cronexp="0 */6 * * *", script-path=https://WORKER/surge-ip-labeler.js, timeout=300, script-update-interval=86400, argument="source_url=%source_url%&upload_url=%upload_url%&upload_token=%upload_token%"
