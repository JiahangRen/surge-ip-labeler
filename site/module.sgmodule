#!name=Surge IP Labeler
#!desc=Safely labels a private Surge policy feed with exit-IP intelligence.
#!arguments=configuration=REQUIRED_CONFIGURATION

[Script]
surge-ip-labeler = type=cron, cronexp="0 */6 * * *", script-path=https://jiahangren.github.io/surge-ip-labeler/surge-ip-labeler.js?rev=20e5e01, timeout=300, script-update-interval=86400, argument="%configuration%"
surge-ip-labeler-now = type=generic, script-path=https://jiahangren.github.io/surge-ip-labeler/surge-ip-labeler.js?rev=20e5e01, timeout=300, script-update-interval=86400, argument="%configuration%"
